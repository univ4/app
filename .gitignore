# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local artifacts
supabase/.branches
supabase/.temp

# misc
.DS_Store

# 개인 데이터 (성적표, 생활기록부 - 절대 커밋 금지)
# (record/ 단독이면 .gitkeep 재포함 불가 → record/** + 예외)
record/**
!record/.gitkeep

# 나이스 PNG 캡처 (개인 데이터)
*.png
# 단, public 폴더 내 이미지는 허용
!public/**/*.png
!src/**/*.png

# 환경변수 추가
.env
.env*.local

# Python
__pycache__/
*.py[cod]
*.pyo

# 테스트 커버리지
/coverage
/playwright/.auth
/playwright-report
/test-results

# 로컬 Python 가상환경 (레포 루트)
.venv/

# Supabase 로컬 개발
supabase/migrations/.cache
