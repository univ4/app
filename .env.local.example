# Supabase (Public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (Server)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=
# Example: claude-sonnet-4-5-20250929
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# GitHub (private Release 자산: data-collector ingest 스크립트)
GITHUB_TOKEN=

# OpenAI Embeddings
OPENAI_API_KEY=
# Fixed by design docs
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI 챗봇 (/api/chat) 일일 호출 상한 (UTC 일자, 사용자별)
CHAT_DAILY_LIMIT=50

# RAG: guideline_chunks 코사인 유사도 하한 (0~1, 미설정 시 0.55)
CHAT_SIMILARITY_THRESHOLD=0.55

# Admission probability discount factor (2026 의대 증원 보정)
# Example: -3.2
MEDICAL_SHIFT_DISCOUNT_FACTOR=-3.2

